# Discord OAuth2 App credentials
# Create a Discord application at https://discord.com/developers/applications
# Add OAuth2 redirect URI: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your_nextauth_secret_here

# Base URL (optional, defaults to http://localhost:3000)
# In production (Vercel / Cloudflare Pages) set this to your public URL, e.g.:
# NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
# NEXT_PUBLIC_BASE_URL=https://your-project.pages.dev

# Trust the host header — required for local dev and self-hosted deployments.
# Set to true when running behind a reverse proxy or on localhost.
AUTH_TRUST_HOST=true

# Secret for the /api/revalidate endpoint (generate with: openssl rand -base64 32)
# Required only if you use on-demand ISR cache revalidation.
# REVALIDATE_SECRET=your_revalidate_secret_here
